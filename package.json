{
  "name": "radarsimapp",
  "version": "0.0.2",
  "description": "Radar simulation desktop app — model waveforms, targets, and antenna arrays with real-time Range-Doppler visualization",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "dist:win": "electron-builder --win --publish never",
    "dist:mac": "electron-builder --mac --publish never",
    "dist:linux": "electron-builder --linux --publish never",
    "generate-gif": "node scripts/generate-install-gif.js"
  },
  "author": "RadarSimX",
  "license": "SEE LICENSE IN LICENSE.txt",
  "devDependencies": {
    "@napi-rs/canvas": "^0.1.97",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "gif-encoder-2": "^1.0.5"
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "h5wasm": "^0.10.1",
    "koffi": "^2.9.0",
    "plotly.js-dist": "^2.35.0"
  },
  "build": {
    "appId": "com.radarsimx.radarsimapp",
    "productName": "RadarSimApp",
    "copyright": "Copyright © 2026 RadarSimX, LLC",
    "win": {
      "target": "squirrel",
      "icon": "renderer/assets/logo.ico",
      "legalTrademarks": "RadarSimX, LLC"
    },
    "mac": {
      "target": "dmg",
      "icon": "renderer/assets/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "renderer/assets/logo.png"
    },
    "squirrelWindows": {
      "loadingGif": "renderer/assets/install.gif"
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**",
      "radarsimlib/**",
      "node_modules/**"
    ],
    "asarUnpack": [
      "radarsimlib/**",
      "node_modules/koffi/**"
    ]
  }
}
