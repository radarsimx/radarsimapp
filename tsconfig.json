{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": false,
    "sourceMap": false,
    "outDir": "./dist"
  },
  "include": ["types.d.ts", "main.ts", "preload.ts", "bridge.ts"],
  "exclude": ["node_modules", "renderer"]
}
